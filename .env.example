TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=123456789,987654321

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/leader_bot
POSTGRES_DB=leader_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

LLM_PROVIDER=openai
# For local smoke tests without an API key, use: LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional. If empty, OPENAI_CHAT_MODEL is used for OCR/vision too.
OPENAI_OCR_MODEL=
LLM_BASE_URL=

BOT_MODE=polling
ENV=local

DATA_DIR=./data
UPLOADS_DIR=./data/uploads
MATERIALS_DIR=./data/materials

MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,docx,pptx,txt
MAX_CONTEXT_CHUNKS=8
MAX_CONTEXT_CHARS=12000
MAX_USER_QUESTIONS_PER_MINUTE=10
TEMPERATURE=0.2

# OCR fallback for image-based PPTX files.
OCR_ENABLED=true
OCR_MIN_TEXT_CHARS=500
OCR_MAX_IMAGES_PER_DOCUMENT=30
OCR_MAX_IMAGE_SIZE_MB=8
OCR_MIN_IMAGE_WIDTH=600
OCR_MIN_IMAGE_HEIGHT=350

# Approximate admin cost dashboard settings. Update manually when prices change.
VM_RUB_PER_HOUR=4.60
# Optional ISO datetime, for example: 2026-05-11T17:00:00+00:00
VM_BILLING_STARTED_AT=
USD_RUB_RATE=90
OPENAI_CHAT_INPUT_USD_PER_1M=0.15
OPENAI_CHAT_OUTPUT_USD_PER_1M=0.60
OPENAI_EMBEDDING_USD_PER_1M=0.02
YANDEXGPT_INPUT_RUB_PER_1K=0.20
YANDEXGPT_OUTPUT_RUB_PER_1K=0.20
YANDEX_EMBEDDING_RUB_PER_1K=0.0101

# Feature flags.
SHOW_PROJECT_CONTEXT_MENU=false
VIDEO_LIBRARY_ENABLED=false
VIDEO_LIBRARY_URL=
VIDEO_LIBRARY_TITLE=Видео занятий
VIDEO_ACCESS_NOTE=Видео-библиотека пока готовится. Если она будет работать через корпоративный VPN, доступ может зависеть от устройства и сети пользователя.

# User notification scheduler.
NOTIFICATIONS_ENABLED=true
NOTIFICATION_TIMEZONE=Europe/Moscow
NOTIFICATION_CHECK_INTERVAL_SECONDS=30

LOG_LEVEL=INFO
